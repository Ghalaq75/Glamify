# Backend port (use 8080 to avoid macOS AirPlay on port 5000)
PORT=8080

# Node environment
NODE_ENV=development

# MongoDB Atlas connection string (or leave blank to use in-memory MongoDB for testing)
# MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/glamify?retryWrites=true&w=majority

# JWT signing secret — set to a long random string in production
JWT_SECRET=change-me-to-a-long-random-string
