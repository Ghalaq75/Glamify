MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/glamify?retryWrites=true&w=majority
JWT_SECRET=your-super-secret-jwt-key-here
PORT=8080
NODE_ENV=development

# SendGrid (required in production for email verification)
# Create an API key at https://app.sendgrid.com/settings/api_keys
# Verify the FROM address as a Single Sender or via Domain Authentication.
# When SENDGRID_API_KEY or SENDGRID_FROM_EMAIL is missing AND NODE_ENV is not "production",
# verification codes are logged to the server console and returned in the API response
# (devCode field) so you can test locally without sending real emails.
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
